        {
          "name": "Login Akun",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Skrip Otomatisasi Token JWT",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.token) {",
                  "    pm.environment.set(\"token\", jsonData.token);",
                  "    console.log(\"Premium Automation: Token JWT berhasil disimpan ke variabel environment 'token'!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "email",
                  "value": "budi.santoso@gmail.com",
                  "type": "text",
                  "description": "Email akun (wajib)"
                },
                {
                  "key": "password",
                  "value": "Password123!",
                  "type": "text",
                  "description": "Kata sandi akun (wajib)"
                }
